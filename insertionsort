#include <iostream>
using namespace std;

// insertion sort Sort : O(n^2)

int main() 
{
    int arr[5] = {5, 4, 3, 2, 1, };
    int n = 5;
    

    for(int i = 0; i<n-1; i++) {
      int min_else_index=i;
        for(int j =i+1; j<=n-1; j++) {
            if(arr[j] < arr[min_else_index]) {
                min_else_index=j;
            }
        } 
        swap(arr[i],arr[min_else_index]);
    }
   

    for(int i = 0; i <n; i++) {
        cout << arr[i] << " ";
    }

    return 0;
}
